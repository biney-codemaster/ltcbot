DISCORD_TOKEN=
CLIENT_ID=
GUILD_ID=
# Discord user ID of the bot owner (required for /slot create, config, panels, etc.)
OWNER_ID=
# Salon du panel /setup (Start a deal) — affiché après les compteurs de ping slot
START_DEAL_CHANNEL_ID=
# Caps slots (défaut: 10 free / 15 paid)
# SLOT_MAX_FREE=10
# SLOT_MAX_PAID=15
STAFF_ROLE_ID=
# Role assigned silently to the customer (buyer) after they leave a review
# Bot needs Manage Roles + its role must be ABOVE this role in the hierarchy
CUSTOMER_ROLE_ID=

# Seed BIP39 partagée pour LTC / BTC / ETH / SOL (12/24 mots).
# CRYPTO_WALLET_MNEMONIC a priorité ; sinon LTC_WALLET_MNEMONIC ; sinon wallet.mnemonic auto.
# SAUVEGARDE cette seed : sans elle, les fonds escrow sont perdus.
CRYPTO_WALLET_MNEMONIC=
LTC_WALLET_MNEMONIC=

# Wallets owner (sous/surpaiements y sont envoyés silencieusement)
OWNER_LTC_WALLET=
OWNER_BTC_WALLET=
OWNER_ETH_WALLET=
OWNER_SOL_WALLET=

# RPC optionnels (fortement recommandé pour ETH — les RPC publics bloquent souvent les VPS)
# Exemple Alchemy: https://eth-mainnet.g.alchemy.com/v2/TON_API_KEY
ETH_RPC_URL=
# SOL_RPC_URL=

# Salons logs / avis — ID NUMÉRIQUE uniquement (Mode dev Discord → clic droit salon → Copier l'identifiant)
# Exemple: ADMIN_LOGS_CHANNEL_ID=123456789012345678
# PAS le nom du salon, PAS l'ID du serveur.
ADMIN_LOGS_CHANNEL_ID=
PUBLIC_LOGS_CHANNEL_ID=
REVIEWS_CHANNEL_ID=
# Salon où tu postes /howto — bouton "How to use" sur le panel /setup
HOWTO_CHANNEL_ID=
